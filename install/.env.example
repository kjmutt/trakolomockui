# Trakolo Standalone / On-premise — environment configuration
# Copy to .env and adjust before running install.sh (install.sh does this for you
# if .env is missing, generating a random database password).

# --- Database ---
POSTGRES_DB=trakolo
POSTGRES_USER=trakolo
POSTGRES_PASSWORD=changeme

# --- App ---
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# --- License ---
# Path to the .trklic file issued by Trakolo for this workspace (see
# cloud-hosting-azure.html > Standalone / on-premise installation, and
# site/docs.html for how license files are generated and activated).
LICENSE_FILE=./license/workspace.trklic
